---
export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
// import StaffList from "../../components/Sections/StaffList.astro";
import Button from "../../components/UI/Button.astro";
import { useTranslations, useTranslatedPath } from "../../i18n/utils";

const { lang } = Astro.params;
const langParams = lang || 'es';

const t = useTranslations(langParams as any);
const translatePath = useTranslatedPath(langParams as any);
---

<BaseLayout
  lang={langParams as any}
  title={t('about.title')}
  description={t('about.description')}
>
  <PageHeader 
    title={t('about.heading')} 
    subtitle={t('about.subtitle')}
    backgroundImage="https://images.unsplash.com/photo-1438032005730-c779502df39b?w=1920&h=600&fit=crop&crop=center"
    lang={langParams as any}
  />
  
  <section class="py-16">
    <div class="container">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold mb-6">{t('about.missionHeading')}</h2>
          <p class="text-xl text-gray-700 mb-8">
            {t('about.missionText')}
          </p>
          
          <h2 class="text-3xl md:text-4xl font-bold mb-6">{t('about.visionHeading')}</h2>
          <p class="text-xl text-gray-700 mb-8">
            {t('about.visionText')}
          </p>
        </div>
        
        <div>
          <img 
            src="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?w=800&h=600&fit=crop&crop=center" 
            alt={t('about.worshipAlt')} 
            class="rounded-lg shadow-lg object-cover w-full h-full"
          />
        </div>
      </div>
    </div>
  </section>
  
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{t('about.valuesHeading')}</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          {t('about.valuesSubtitle')}
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-16 h-16 rounded-full bg-primary-100 flex items-center justify-center mb-6">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">{t('about.value1Title')}</h3>
          <p class="text-gray-700">
            {t('about.value1Desc')}
          </p>
        </div>
        
        <div class="bg-white p-8 rounded-lg shadow-sm">
          <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mb-6">
