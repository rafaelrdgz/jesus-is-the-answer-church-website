            </svg>
          </div>
          <h3 class="text-xl font-bold mb-3">{t('about.value6Title')}</h3>
          <p class="text-gray-700">
            {t('about.value6Desc')}
          </p>
        </div>
      </div>
    </div>
  </section>
  
