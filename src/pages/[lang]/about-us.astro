              <time class="sm:w-28 text-xs text-gray-500 uppercase">{t('about.history5Year')}</time>
              <div>
                <h3 class="text-xl font-bold text-gray-900">{t('about.history5Title')}</h3>
                <p class="text-gray-700">
                  {t('about.history5Text')}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
