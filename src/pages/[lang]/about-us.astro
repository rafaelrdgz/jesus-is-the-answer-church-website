            <time class="sm:w-28 text-xs text-gray-500 uppercase">{t('about.history1Year')}</time>
            <div>
              <h3 class="text-xl font-bold text-gray-900">{t('about.history1Title')}</h3>
              <p class="text-gray-700">
                {t('about.history1Text')}
