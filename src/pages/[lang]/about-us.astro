                <p class="text-gray-700">
                  {t('about.history2Text')}
                </p>
              </div>
            </div>
          </div>
          
          <div class="relative pl-8 sm:pl-16 py-6 group">
            <div class="flex flex-col sm:flex-row items-start mb-1 group-last:before:hidden before:absolute before:left-2 sm:before:left-7 before:h-full before:px-px before:bg-gray-300 before:self-start before:-translate-x-1/2 before:translate-y-3 after:absolute after:left-2 sm:after:left-7 after:w-4 after:h-4 after:bg-primary-600 after:border-4 after:border-white after:rounded-full after:-translate-x-1/2 after:translate-y-1.5">
              <time class="sm:w-28 text-xs text-gray-500 uppercase">{t('about.history3Year')}</time>
              <div>
                <h3 class="text-xl font-bold text-gray-900">{t('about.history3Title')}</h3>
                <p class="text-gray-700">
                  {t('about.history3Text')}
                </p>
              </div>
            </div>
          </div>
          
          <div class="relative pl-8 sm:pl-16 py-6 group">
            <div class="flex flex-col sm:flex-row items-start mb-1 group-last:before:hidden before:absolute before:left-2 sm:before:left-7 before:h-full before:px-px before:bg-gray-300 before:self-start before:-translate-x-1/2 before:translate-y-3 after:absolute after:left-2 sm:after:left-7 after:w-4 after:h-4 after:bg-primary-600 after:border-4 after:border-white after:rounded-full after:-translate-x-1/2 after:translate-y-1.5">
              <time class="sm:w-28 text-xs text-gray-500 uppercase">{t('about.history4Year')}</time>
              <div>
                <h3 class="text-xl font-bold text-gray-900">{t('about.history4Title')}</h3>
                <p class="text-gray-700">
                  {t('about.history4Text')}
                </p>
              </div>
            </div>
