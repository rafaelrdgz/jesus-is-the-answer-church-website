---
export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/Sections/PageHeader.astro";
import Card from "../../../components/UI/Card.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../../utils/dateUtils";
import { useTranslations, useTranslatedPath } from "../../../i18n/utils";
import { filterByLocale, getSlugFromId, localizedField } from "../../../i18n/utils";

const { lang } = Astro.params;
const langParams = lang || 'es';

const t = useTranslations(langParams as any);
const translatePath = useTranslatedPath(langParams as any);

const allSermons = await getCollection("sermons", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const localeSermons = filterByLocale(allSermons, langParams as any);

const sermons = localeSermons.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const series = [...new Set(sermons.map(sermon => localizedField(sermon.data.series, langParams as any)).filter(Boolean))];
const speakers = [...new Set(sermons.map(sermon => localizedField(sermon.data.speaker, langParams as any)).filter(Boolean))];

---

<BaseLayout
  lang={langParams as any}
  title={t('sermons.title')}
  description={t('sermons.description')}
>
  <PageHeader 
    title={t('sermons.heading')} 
    subtitle={t('sermons.subtitle')}
    backgroundImage="/uploads/sermons-header-bg.webp"
    lang={langParams as any}
  />
  
  <section class="py-16">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <div class="lg:col-span-1">
          <div class="bg-white p-6 rounded-lg shadow-sm sticky top-24">
            <h2 class="text-xl font-bold mb-6">{t('sermons.filterHeading')}</h2>
            
            <div class="mb-6">
              <label for="search" class="block text-sm font-medium text-gray-700 mb-1">{t('sermons.searchLabel')}</label>
              <input 
                type="text" 
                id="search" 
                placeholder={t('sermons.searchPlaceholder')}
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
              />
            </div>
            
            {series.length > 0 && (
              <div class="mb-6">
                <label for="series" class="block text-sm font-medium text-gray-700 mb-1">{t('sermons.seriesLabel')}</label>
                <select id="series" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500">
                  <option value="">{t('sermons.allSeries')}</option>
                  {series.map(s => (
                    <option value={s}>{s}</option>
                  ))}
                </select>
              </div>
            )}
            
            {speakers.length > 0 && (
              <div class="mb-6">
                <label for="speaker" class="block text-sm font-medium text-gray-700 mb-1">{t('sermons.speakerLabel')}</label>
                <select id="speaker" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500">
                  <option value="">{t('sermons.allSpeakers')}</option>
                  {speakers.map(s => (
                    <option value={s}>{s}</option>
                  ))}
                </select>
              </div>
            )}
            
            <div class="space-y-3">
              <label class="block text-sm font-medium text-gray-700">{t('sermons.dateRangeLabel')}</label>
              
              <div>
                <label for="from-date" class="block text-xs text-gray-500 mb-1">{t('sermons.dateFrom')}</label>
                <input type="date" id="from-date" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500" />
              </div>
              
              <div>
                <label for="to-date" class="block text-xs text-gray-500 mb-1">{t('sermons.dateTo')}</label>
                <input type="date" id="to-date" class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500" />
              </div>
            </div>
            
            <button id="reset-filters" class="w-full mt-6 px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200">
              {t('sermons.resetFilters')}
            </button>
          </div>
        </div>
        
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold mb-6">{t('sermons.allSermons')}</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="sermons-grid">
            {sermons.map((sermon) => (
              <Card
                title={localizedField(sermon.data.title, langParams as any)}
                image={{
                  src: sermon.data.image || "/uploads/sermon-placeholder.webp",
                  alt: localizedField(sermon.data.title, langParams as any)
                }}
                href={`${translatePath('/sermones')}/${getSlugFromId(sermon.id)}`}
                className="sermon-card"
                dataSeries={localizedField(sermon.data.series, langParams as any) || ""}
                dataSpeaker={localizedField(sermon.data.speaker, langParams as any)}
                dataDate={sermon.data.date.toISOString().slice(0, 10)}
              >
                <div class="mb-3 flex items-center text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span>{formatDate(sermon.data.date, langParams as any)}</span>
                </div>
                
                <div class="mb-3 flex items-center text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <span>{localizedField(sermon.data.speaker, langParams as any)}</span>
                </div>
                
                {localizedField(sermon.data.series, langParams as any) && (
                  <div class="mb-3 flex items-center text-gray-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    <span>{t('sermons.seriesPrefix')}{localizedField(sermon.data.series, langParams as any)}</span>
                  </div>
                )}
                
                {localizedField(sermon.data.scripture, langParams as any) && (
                  <div class="mb-3 flex items-center text-gray-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                    <span>{localizedField(sermon.data.scripture, langParams as any)}</span>
                  </div>
                )}
                
                <p class="text-gray-700 mb-4">{localizedField(sermon.data.summary, langParams as any)}</p>

                <p class="text-primary-600 font-medium group-hover:underline group-hover:text-primary-700">
                  {t('sermons.listenWatch')}
                </p>
              </Card>
            ))}
          </div>
          
          <div id="no-results" class="hidden text-center py-12 bg-gray-50 rounded-lg mt-8">
            <p class="text-gray-600">{t('sermons.noResults')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('search');
      const seriesSelect = document.getElementById('series');
      const speakerSelect = document.getElementById('speaker');
      const fromDateInput = document.getElementById('from-date');
      const toDateInput = document.getElementById('to-date');
      const resetButton = document.getElementById('reset-filters');
      const sermonCards = document.querySelectorAll('.sermon-card');
      const noResults = document.getElementById('no-results');
      
      const filterSermons = () => {
        const searchTerm = searchInput?.value.toLowerCase() || '';
        const selectedSeries = seriesSelect?.value || '';
        const selectedSpeaker = speakerSelect?.value || '';
        const fromDate = fromDateInput?.value || '';
        const toDate = toDateInput?.value || '';
        
        let visibleCount = 0;
        
        sermonCards.forEach(card => {
          const title = card.querySelector('h3')?.textContent.toLowerCase() || '';
          const summary = card.querySelector('p')?.textContent.toLowerCase() || '';
          const series = card.getAttribute('data-series') || '';
          const speaker = card.getAttribute('data-speaker') || '';
          const date = card.getAttribute('data-date') || '';
          
          const matchesSearch = title.includes(searchTerm) || summary.includes(searchTerm);
          const matchesSeries = !selectedSeries || series === selectedSeries;
          const matchesSpeaker = !selectedSpeaker || speaker === selectedSpeaker;
          const matchesFromDate = !fromDate || date >= fromDate;
          const matchesToDate = !toDate || date <= toDate;
          
          if (matchesSearch && matchesSeries && matchesSpeaker && matchesFromDate && matchesToDate) {
            card.style.display = 'block';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        if (noResults) {
          noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      };
      
      searchInput?.addEventListener('input', filterSermons);
      seriesSelect?.addEventListener('change', filterSermons);
      speakerSelect?.addEventListener('change', filterSermons);
      fromDateInput?.addEventListener('change', filterSermons);
      toDateInput?.addEventListener('change', filterSermons);
      
      resetButton?.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        if (seriesSelect) seriesSelect.value = '';
        if (speakerSelect) speakerSelect.value = '';
        if (fromDateInput) fromDateInput.value = '';
        if (toDateInput) toDateInput.value = '';
        filterSermons();
      });
    });
  </script>
</BaseLayout>
