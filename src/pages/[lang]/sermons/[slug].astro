---
export const prerender = true;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostLayout from "../../../layouts/PostLayout.astro";
import Button from "../../../components/UI/Button.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../../utils/dateUtils";
import { useTranslations, useTranslatedPath, filterByLocale, getSlugFromId, localizedField } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";

export async function getStaticPaths() {
  const sermonEntries = await getCollection("sermons", ({ data }) => {
    return import.meta.env.PROD ? !data.draft : true;
  });

  const paths = [];
  
  // Only generate ES paths for ES entries and EN paths for EN entries
  for (const entry of filterByLocale(sermonEntries, 'es')) {
    paths.push({
      params: { lang: 'es', slug: getSlugFromId(entry.id) },
      props: { entry, lang: 'es' as Lang },
    });
  }
  for (const entry of filterByLocale(sermonEntries, 'en')) {
    paths.push({
      params: { lang: 'en', slug: getSlugFromId(entry.id) },
      props: { entry, lang: 'en' as Lang },
    });
  }
  
  return paths;
}

const { entry, lang } = Astro.props;
const langParams = lang as Lang;

const t = useTranslations(langParams);
const translatePath = useTranslatedPath(langParams);
const { Content } = await entry.render();

const localizedTitle = localizedField(entry.data.title, langParams);
const localizedSummary = localizedField(entry.data.summary, langParams);
const localizedSpeaker = localizedField(entry.data.speaker, langParams);
const localizedSeries = localizedField(entry.data.series, langParams);
const localizedScripture = localizedField(entry.data.scripture, langParams);
const formattedDate = formatDate(entry.data.date, langParams);
---

<BaseLayout
  lang={langParams}
  title={`${localizedTitle} - Sermons - Church Name`}
  description={localizedSummary || `Listen to "${localizedTitle}" by ${localizedSpeaker}`}
  image={entry.data.image ? { url: entry.data.image, alt: localizedTitle } : undefined}
  type="article"
>
  <PostLayout
    title={localizedTitle}
    description={localizedSummary}
    image={entry.data.image ? { url: entry.data.image, alt: localizedTitle } : undefined}
    date={entry.data.date}
    author={localizedSpeaker}
    tags={entry.data.tags}
    type="sermon"
    lang={langParams}
  >
    <div class="bg-gray-50 rounded-lg p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <div class="mb-4">
            <h3 class="text-lg font-bold mb-2">{t('sermonDetail.speakerLabel')}</h3>
            <p class="flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              {localizedSpeaker}
            </p>
          </div>
          
          {localizedSeries && (
            <div class="mb-4">
              <h3 class="text-lg font-bold mb-2">{t('sermonDetail.seriesLabel')}</h3>
              <p class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
                {localizedSeries}
              </p>
            </div>
          )}
        </div>
        
        <div>
          <div class="mb-4">
            <h3 class="text-lg font-bold mb-2">{t('sermonDetail.dateLabel')}</h3>
            <p class="flex items-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {formattedDate}
            </p>
          </div>
          
          {localizedScripture && (
            <div>
              <h3 class="text-lg font-bold mb-2">{t('sermonDetail.scriptureLabel')}</h3>
              <p class="flex items-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                {localizedScripture}
              </p>
            </div>
          )}
        </div>
      </div>
    </div>
    
    <div class="mb-8 space-y-6">
      {entry.data.videoUrl && (
        <div>
          <h3 class="text-xl font-bold mb-4">{t('sermonDetail.watchHeading')}</h3>
          <div class="aspect-w-16 aspect-h-9 rounded-lg overflow-hidden">
            <iframe 
              src={entry.data.videoUrl} 
              title={localizedTitle}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
              allowfullscreen
              class="w-full h-full"
            ></iframe>
          </div>
        </div>
      )}
      
      {entry.data.audioUrl && (
        <div>
          <h3 class="text-xl font-bold mb-4">{t('sermonDetail.listenHeading')}</h3>
          <audio controls class="w-full">
            <source src={entry.data.audioUrl} type="audio/mpeg">
            {t('sermonDetail.audioFallback')}
          </audio>
        </div>
      )}
    </div>
    
    <article class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-h1:text-3xl prose-h2:text-2xl prose-h3:text-xl prose-h4:text-lg prose-p:text-gray-700 prose-li:text-gray-700 prose-strong:text-gray-900 prose-a:text-primary-600 hover:prose-a:text-primary-700">
      <Content />
    </article>
    
    <div class="mt-12 flex flex-wrap gap-4">
      <Button href={translatePath('/sermones')} variant="outline">
        {t('sermonDetail.backToAll')}
      </Button>
    </div>
  </PostLayout>
</BaseLayout>
