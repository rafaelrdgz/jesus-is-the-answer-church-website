---
export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/Sections/PageHeader.astro";
import Card from "../../../components/UI/Card.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../../utils/dateUtils";
import { useTranslations, useTranslatedPath, filterByLocale, getSlugFromId, localizedField } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/ui";

const { lang } = Astro.params;
const langParams = (lang || 'es') as Lang;

const t = useTranslations(langParams);
const translatePath = useTranslatedPath(langParams);

const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const posts = filterByLocale(allPosts, langParams).sort((a, b) => 
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const tags = [...new Set(posts.flatMap(post => post.data.tags))];
---

<BaseLayout
  lang={langParams}
  title={t('blog.title')}
  description={t('blog.description')}
>
  <PageHeader 
    title={t('blog.heading')} 
    subtitle={t('blog.subtitle')}
    backgroundImage="/uploads/blog-header-bg.webp"
    lang={langParams}
  />
  
  <section class="py-16">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <div class="lg:col-span-1">
          <div class="bg-white p-6 rounded-lg shadow-sm sticky top-24">
            <h2 class="text-xl font-bold mb-6">{t('blog.filterHeading')}</h2>
            
            <div class="mb-6">
              <label for="search" class="block text-sm font-medium text-gray-700 mb-1">{t('blog.searchLabel')}</label>
              <input 
                type="text" 
                id="search" 
                placeholder={t('blog.searchPlaceholder')}
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
              />
            </div>
            
            {tags.length > 0 && (
              <div class="mb-6">
                <h3 class="block text-sm font-medium text-gray-700 mb-2">{t('blog.tagsLabel')}</h3>
                <div class="space-y-2">
                  {tags.map(tag => (
                    <label class="flex items-center">
                      <input type="checkbox" class="tag-checkbox h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded" value={tag} />
                      <span class="ml-2 text-gray-700">{tag}</span>
                    </label>
                  ))}
                </div>
              </div>
            )}
            
            <div class="mb-6">
              <label for="author" class="block text-sm font-medium text-gray-700 mb-1">{t('blog.authorLabel')}</label>
              <input 
                type="text" 
                id="author" 
                placeholder={t('blog.authorPlaceholder')}
                class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
              />
            </div>
            
            <div class="space-y-3">
              <label class="block text-sm font-medium text-gray-700">{t('blog.dateRangeLabel')}</label>
              
              <div>
                <label for="from-date" class="block text-xs text-gray-500 mb-1">{t('blog.dateFrom')}</label>
                <input 
                  type="date" 
                  id="from-date" 
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
                />
              </div>
              
              <div>
                <label for="to-date" class="block text-xs text-gray-500 mb-1">{t('blog.dateTo')}</label>
                <input 
                  type="date" 
                  id="to-date" 
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:ring-primary-500 focus:border-primary-500"
                />
              </div>
            </div>
            
            <button 
              id="reset-filters"
              class="w-full mt-6 px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2"
            >
              {t('blog.resetFilters')}
            </button>
          </div>
        </div>
        
        <div class="lg:col-span-3">
          <h2 class="text-2xl font-bold mb-6">{t('blog.allPosts')}</h2>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8" id="posts-grid">
            {posts.map((post) => (
              <Card
                title={localizedField(post.data.title, langParams)}
                image={post.data.image && {
                  src: post.data.image.url,
                  alt: localizedField(post.data.image.alt, langParams)
                }}
                href={`${translatePath('/blog')}/${getSlugFromId(post.id)}`}
                className="blog-card"
                data-tags={post.data.tags.join(',')}
                data-author={localizedField(post.data.author, langParams)}
                data-date={post.data.pubDate.toISOString().slice(0, 10)}
              >
                <div class="mb-3 flex items-center text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                  <span>{formatDate(post.data.pubDate, langParams)}</span>
                </div>
                
                <div class="mb-3 flex items-center text-gray-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                  <span>{localizedField(post.data.author, langParams)}</span>
                </div>
                
                <p class="text-gray-700 mb-4">{localizedField(post.data.description, langParams)}</p>
                
                {post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.data.tags.map((tag) => (
                      <span class="px-2 py-1 text-xs font-medium text-primary-700 bg-primary-100 rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}

                <p class="text-primary-600 font-medium group-hover:underline group-hover:text-primary-700">
                  {t('blog.readMore')}
                </p>
              </Card>
            ))}
          </div>
          
          <div id="no-results" class="hidden text-center py-12 bg-gray-50 rounded-lg mt-8">
            <p class="text-gray-600">{t('blog.noResults')}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('search');
      const authorInput = document.getElementById('author');
      const tagCheckboxes = document.querySelectorAll('.tag-checkbox');
      const fromDateInput = document.getElementById('from-date');
      const toDateInput = document.getElementById('to-date');
      const resetButton = document.getElementById('reset-filters');
      const blogCards = document.querySelectorAll('.blog-card');
      const noResults = document.getElementById('no-results');
      
      const filterPosts = () => {
        const searchTerm = searchInput?.value.toLowerCase() || '';
        const authorTerm = authorInput?.value.toLowerCase() || '';
        const fromDate = fromDateInput?.value || '';
        const toDate = toDateInput?.value || '';
        
        const selectedTags = Array.from(tagCheckboxes)
          .filter(checkbox => checkbox.checked)
          .map(checkbox => checkbox.value);
        
        let visibleCount = 0;
        
        blogCards.forEach(card => {
          const title = card.querySelector('h3')?.textContent.toLowerCase() || '';
          const description = card.querySelector('p')?.textContent.toLowerCase() || '';
          const author = card.getAttribute('data-author')?.toLowerCase() || '';
          const date = card.getAttribute('data-date') || '';
          const tags = (card.getAttribute('data-tags') || '').split(',');
          
          const matchesSearch = title.includes(searchTerm) || description.includes(searchTerm);
          const matchesAuthor = !authorTerm || author.includes(authorTerm);
          const matchesFromDate = !fromDate || date >= fromDate;
          const matchesToDate = !toDate || date <= toDate;
          const matchesTags = selectedTags.length === 0 || selectedTags.some(tag => tags.includes(tag));
          
          if (matchesSearch && matchesAuthor && matchesFromDate && matchesToDate && matchesTags) {
            card.style.display = 'block';
            visibleCount++;
          } else {
            card.style.display = 'none';
          }
        });
        
        if (noResults) {
          noResults.style.display = visibleCount === 0 ? 'block' : 'none';
        }
      };
      
      searchInput?.addEventListener('input', filterPosts);
      authorInput?.addEventListener('input', filterPosts);
      tagCheckboxes.forEach(checkbox => checkbox.addEventListener('change', filterPosts));
      fromDateInput?.addEventListener('change', filterPosts);
      toDateInput?.addEventListener('change', filterPosts);
      
      resetButton?.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        if (authorInput) authorInput.value = '';
        tagCheckboxes.forEach(checkbox => checkbox.checked = false);
        if (fromDateInput) fromDateInput.value = '';
        if (toDateInput) toDateInput.value = '';
        filterPosts();
      });
    });
  </script>
</BaseLayout>
