---
export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHeader from "../../components/Sections/PageHeader.astro";
import StaffList from "../../components/Sections/StaffList.astro";
import Button from "../../components/UI/Button.astro";
import { useTranslations, useTranslatedPath } from "../../i18n/utils";

const { lang } = Astro.params;
const langParams = lang || 'es';

const t = useTranslations(langParams as any);
const translatePath = useTranslatedPath(langParams as any);
---

<BaseLayout
  lang={langParams as any}
  title={t('staff.title')}
  description={t('staff.description')}
>
  <PageHeader 
    title={t('staff.heading')} 
    subtitle={t('staff.subtitle')}
    backgroundImage="https://images.unsplash.com/photo-1552664730-d307ca884978?w=1920&h=600&fit=crop&crop=center"
    lang={langParams as any}
  />
  
  <section class="py-16">
    <div class="container">
      <StaffList showAll={true} lang={langParams as any} />
    </div>
  </section>
  
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{t('staff.contactHeading')}</h2>
        <p class="text-xl text-gray-600 mb-8">
          {t('staff.contactText')}
        </p>
        
        <Button href={translatePath('/contacto')} variant="primary">
          {t('staff.contactCta')}
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
