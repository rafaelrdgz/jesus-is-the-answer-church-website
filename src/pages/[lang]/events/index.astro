---
export const prerender = true;

export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
  ];
}

import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageHeader from "../../../components/Sections/PageHeader.astro";
import Card from "../../../components/UI/Card.astro";
import Button from "../../../components/UI/Button.astro";
import { getCollection } from "astro:content";
import { formatDate, isFutureDate, isPastDate } from "../../../utils/dateUtils";
import { useTranslations, useTranslatedPath } from "../../../i18n/utils";
import { filterByLocale, getSlugFromId, localizedField } from "../../../i18n/utils";

const { lang } = Astro.params;
const langParams = lang || 'es';

const t = useTranslations(langParams as any);
const translatePath = useTranslatedPath(langParams as any);

const allEvents = await getCollection("events", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const localeEvents = filterByLocale(allEvents, langParams as any);

const upcomingEvents = localeEvents.filter(event => isFutureDate(event.data.date))
                            .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const pastEvents = localeEvents.filter(event => isPastDate(event.data.date))
                        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
                        .slice(0, 6);

---

<BaseLayout
  lang={langParams as any}
  title={t('events.title')}
  description={t('events.description')}
>
  <PageHeader 
    title={t('events.heading')} 
    subtitle={t('events.subtitle')}
    backgroundImage="/uploads/events-header-bg.webp"
    lang={langParams as any}
  />
  
  <section class="py-16">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{t('events.upcomingHeading')}</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          {t('events.upcomingSubtitle')}
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {upcomingEvents.map((event) => (
          <Card
            title={localizedField(event.data.title, langParams as any)}
            image={{
              src: event.data.image,
              alt: localizedField(event.data.title, langParams as any)
            }}
            href={`${translatePath('/eventos')}/${getSlugFromId(event.id)}`}
          >
            <div class="mb-3 flex items-center text-gray-600">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span>{formatDate(event.data.date, langParams as any)}</span>
            </div>
            
            {event.data.time && (
              <div class="mb-3 flex items-center text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>{event.data.time}</span>
              </div>
            )}
            
            <div class="mb-3 flex items-center text-gray-600">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <span>{localizedField(event.data.location, langParams as any)}</span>
            </div>
            
            <p class="text-gray-700 mb-4">{localizedField(event.data.summary, langParams as any)}</p>
            
            <p class="text-primary-600 font-medium group-hover:underline group-hover:text-primary-700">
              {t('events.learnMore')}
            </p>
          </Card>
        ))}
      </div>
    </div>
  </section>
  
  <section class="py-16 bg-gray-50">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">{t('events.pastHeading')}</h2>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          {t('events.pastSubtitle')}
        </p>
      </div>
      
      {pastEvents.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {pastEvents.map((event) => (
            <Card
              title={localizedField(event.data.title, langParams as any)}
              image={{
                src: event.data.image,
                alt: localizedField(event.data.title, langParams as any)
              }}
              href={`${translatePath('/eventos')}/${getSlugFromId(event.id)}`}
              className="opacity-90 hover:opacity-100"
            >
              <div class="mb-3 flex items-center text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <span>{formatDate(event.data.date, langParams as any)}</span>
              </div>
              
              <div class="mb-3 flex items-center text-gray-600">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>{localizedField(event.data.location, langParams as any)}</span>
              </div>
              
              <p class="text-gray-700 mb-4">{localizedField(event.data.summary, langParams as any)}</p>

              <p class="text-primary-600 font-medium group-hover:underline group-hover:text-primary-700">
                {t('events.viewDetails')}
              </p>
            </Card>
          ))}
        </div>
      ) : (
        <div class="text-center py-12 bg-white rounded-lg shadow-sm">
          <p class="text-gray-600">{t('events.noPast')}</p>
        </div>
      )}
    </div>
  </section>
  
  <section class="py-20 bg-white">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">{t('events.ctaHeading')}</h2>
        <p class="text-xl text-gray-600 mb-8">
          {t('events.ctaText')}
        </p>
        
        <Button href={translatePath('/contacto')} variant="primary">
          {t('events.submitEvent')}
        </Button>
      </div>
    </div>
  </section>
</BaseLayout>
