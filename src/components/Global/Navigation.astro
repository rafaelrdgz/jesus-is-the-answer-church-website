---
import LanguagePicker from './LanguagePicker.astro';
import type { Lang } from '../../i18n/ui';
import { defaultLang } from '../../i18n/ui';
import { useTranslations, useTranslatedPath } from '../../i18n/utils';

export interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Define the navigation items using translations and translated paths
const navItems = [
  { text: t('nav.home'), href: translatePath('/') },
  { text: t('nav.about'), href: translatePath('/nosotros') },
  // { text: t('nav.staff'), href: translatePath('/personal') },
  { text: t('nav.ministries'), href: translatePath('/ministerios') },
  { text: t('nav.sermons'), href: translatePath('/sermones') },
  { text: t('nav.events'), href: translatePath('/eventos') },
  { text: t('nav.blog'), href: translatePath('/blog') },
  { text: t('nav.imNew'), href: translatePath('/soy-nuevo') },
  { text: t('nav.contact'), href: translatePath('/contacto') },
  { text: t('nav.giving'), href: translatePath('/ofrenda') },
];

// Get the current URL path to highlight the active link
const currentPath = Astro.url.pathname;

// Helper function to check if current path matches the nav item
const isActive = (itemHref: string) => {
  // Get the current path without trailing slash for comparison
  const currentPathname = currentPath.replace(/\/$/, '') || '/';
  
  // For the homepage (e.g., /es/ or /en/), only match exactly
  if (itemHref === '/es/' || itemHref === '/en/') {
    return currentPathname === itemHref.replace(/\/$/, '');
  }
  
  // For other pages, check if current path matches exactly or starts with the href + '/'
  // This prevents /es/contacto from matching /es/
  return currentPathname === itemHref || currentPathname.startsWith(itemHref + '/');
};
---

<!-- Desktop Navigation -->
<nav class="hidden lg:flex items-center">
  <ul class="flex items-center space-x-6">
      {
        navItems.map((item) => {
          const active = isActive(item.href);
          
          return (
            <li>
              <a
                href={item.href}
                class={`text-base font-medium transition-colors hover:text-primary-600 ${
                  active ? "text-primary-600" : "text-gray-700"
                }`}
                aria-current={active ? "page" : undefined}
              >
                {item.text}
              </a>
            </li>
          );
        })
      }
    
    <!-- Language Picker -->
    <li>
      <LanguagePicker lang={lang} variant="desktop" />
    </li>
  </ul>
</nav>

<!-- Mobile Menu Button -->
<div class="flex items-center gap-2 lg:hidden">
  <LanguagePicker lang={lang} variant="mobile" />
  <button
    id="mobile-menu-button"
    class="p-2 text-gray-700 hover:text-primary-600 focus:outline-none transition-colors relative"
    aria-label="Toggle Menu"
    aria-expanded="false"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
  </button>
</div>

<!-- Mobile Menu Dropdown - Compact & Clean -->
<div
  id="mobile-menu"
  class="absolute top-full left-0 right-0 bg-white shadow-lg border-t border-gray-100 transform scale-y-0 origin-top transition-transform duration-200 ease-out lg:hidden z-40"
  role="menu"
  aria-labelledby="mobile-menu-button"
>
  <!-- Navigation Links in Grid -->
  <div class="px-4 py-6">
    <div class="grid grid-cols-2 gap-3">
      {
        navItems.map((item) => {
          const active = isActive(item.href);
          
          return (
            <a
              href={item.href}
              class={`block px-4 py-3 text-sm font-medium rounded-lg transition-colors text-center ${
                active 
                  ? "bg-primary-50 text-primary-600 border border-primary-200" 
                  : "text-gray-700 hover:bg-gray-50 hover:text-primary-600 border border-transparent"
              }`}
              role="menuitem"
              aria-current={active ? "page" : undefined}
            >
              {item.text}
            </a>
          );
        })
      }
    </div>
  </div>
</div>

<style>
  /* Mobile menu button animation */
  #mobile-menu-button:hover svg {
    transform: scale(1.1);
  }
  
  #mobile-menu-button svg {
    transition: transform 0.2s ease;
  }
  
  /* Mobile menu show/hide states */
  #mobile-menu.show {
    transform: scaleY(1);
  }
  
  /* Smooth hover effects */
  #mobile-menu a {
    transition: all 0.15s ease;
  }
  
  /* Active state styling */
  #mobile-menu a[aria-current="page"] {
    font-weight: 600;
  }
</style>

<script>
  // Mobile menu functionality
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuButton = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const langPickerBtn = document.getElementById('lang-picker-btn');
    const langPickerDropdown = document.getElementById('lang-picker-dropdown');
    
    let isMenuOpen = false;
    
    // Function to toggle mobile menu
    const toggleMobileMenu = () => {
      isMenuOpen = !isMenuOpen;
      
      if (isMenuOpen) {
        // Show menu
        mobileMenu.classList.add('show');
        mobileMenuButton.setAttribute('aria-expanded', 'true');
        // Close language picker when opening mobile menu
        if (langPickerDropdown) {
          langPickerDropdown.classList.remove('show');
          if (langPickerBtn) langPickerBtn.setAttribute('aria-expanded', 'false');
        }
      } else {
        // Hide menu
        mobileMenu.classList.remove('show');
        mobileMenuButton.setAttribute('aria-expanded', 'false');
      }
    };
    
    // Event listeners
    mobileMenuButton?.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMobileMenu();
    });
    
    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (isMenuOpen && !mobileMenu.contains(e.target) && !mobileMenuButton.contains(e.target)) {
        toggleMobileMenu();
      }
    });
    
    // Close menu when clicking a navigation link
    const navLinks = mobileMenu?.querySelectorAll('a[href^="/"]');
    navLinks?.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) {
          setTimeout(() => toggleMobileMenu(), 100);
        }
      });
    });
    
    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) {
        toggleMobileMenu();
      }
    });
    
    // Handle window resize
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1024 && isMenuOpen) {
        toggleMobileMenu();
      }
    });
  });
</script>
