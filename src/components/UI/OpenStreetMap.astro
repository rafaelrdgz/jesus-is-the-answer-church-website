---
export interface Props {
  height?: string;
  className?: string;
  lat?: number;
  lng?: number;
  markerText?: string;
}

const { 
  height = "450px", 
  className = "",
  lat = 23.16717896293332,
  lng = -82.26415494639271,
  markerText = "Iglesia"
} = Astro.props;
---

<div 
  class:list={["rounded-lg overflow-hidden", className]}
  style={`height: ${height}; z-index: 0;`}
  data-leaflet-map
  data-lat={lat}
  data-lng={lng}
  data-marker-text={markerText}
>
  <div id="map" class="w-full h-full"></div>
</div>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<style is:global>
  .leaflet-pane,
  .leaflet-tile,
  .leaflet-marker-icon,
  .leaflet-control {
    z-index: 1 !important;
  }
  
  .leaflet-map-pane {
    z-index: 1 !important;
  }

  .leaflet-control-zoom {
    z-index: 1 !important;
  }

  .leaflet-control-container .leaflet-top,
  .leaflet-control-container .leaflet-bottom {
    z-index: 1 !important;
  }
</style>

<script>
  function initMap() {
    const mapContainers = document.querySelectorAll('[data-leaflet-map]');
    
    mapContainers.forEach((container) => {
      const lat = parseFloat(container.getAttribute('data-lat') || '23.16717896293332');
      const lng = parseFloat(container.getAttribute('data-lng') || '-82.26415494639271');
      const markerText = container.getAttribute('data-marker-text') || 'Iglesia';
      
      const mapElement = container.querySelector('#map');
      if (!mapElement || (mapElement as HTMLElement).dataset.leafletInitialized) return;
      (mapElement as HTMLElement).dataset.leafletInitialized = 'true';
      
      const L = (window as any).L;
      
      const map = L.map('map').setView([lat, lng], 16);
      
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
      }).addTo(map);
      
      const icon = L.icon({
        iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
        iconRetinaUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon-2x.png',
        shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
        iconSize: [25, 41],
        iconAnchor: [12, 41],
        popupAnchor: [1, -34],
        shadowSize: [41, 41]
      });
      
      L.marker([lat, lng], { icon: icon }).addTo(map)
        .bindPopup(markerText)
        .openPopup();
    });
  }

  function loadLeaflet() {
    return new Promise<void>((resolve) => {
      if ((window as any).L) {
        resolve();
        return;
      }
      
      const script = document.createElement('script');
      script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
      script.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=';
      script.crossOrigin = '';
      script.onload = () => resolve();
      document.head.appendChild(script);
    });
  }

  loadLeaflet().then(initMap);
</script>
