---
import { getCollection } from "astro:content";
import Card from "../UI/Card.astro";
import Button from "../UI/Button.astro";
import { formatDate } from "../../utils/dateUtils";
import type { Lang } from "../../i18n/ui";
import { defaultLang } from "../../i18n/ui";
import { useTranslations, useTranslatedPath } from "../../i18n/utils";
import { filterByLocale, getSlugFromId, localizedField } from "../../i18n/utils";

export interface Props {
  count?: number;
  showViewAll?: boolean;
  lang?: Lang;
}

const { count = 3, showViewAll = true, lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

// Get events filtered by locale, sorted by date (upcoming first)
const allEvents = await getCollection("events", ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const localeEvents = filterByLocale(allEvents, lang);

// Sort by date (upcoming first), only future events
const events = localeEvents
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime())
  .filter(event => new Date(event.data.date) >= new Date())
  .slice(0, count);
---

<section class="py-16 bg-gray-50">
  <div class="container">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{t('eventList.heading')}</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        {t('eventList.subtitle')}
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {events.map((event) => (
        <Card
          title={localizedField(event.data.title, lang)}
          image={{
            src: event.data.image,
            alt: localizedField(event.data.title, lang)
          }}
          href={`${translatePath('/eventos')}/${getSlugFromId(event.id)}`}
        >
          <div class="mb-3 flex items-center text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span>{formatDate(event.data.date, lang)}</span>
          </div>
          
          <div class="mb-3 flex items-center text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{localizedField(event.data.location, lang)}</span>
          </div>
          
          <p class="text-gray-700 mb-4">{localizedField(event.data.summary, lang)}</p>
          
          <p class="text-primary-600 font-medium group-hover:underline group-hover:text-primary-700">
            {t('eventList.learnMore')}
          </p>
        </Card>
      ))}
    </div>
    
    {showViewAll && events.length > 0 && (
      <div class="mt-12 text-center">
        <Button href={translatePath('/eventos')} variant="outline">
          {t('eventList.viewAll')}
        </Button>
      </div>
    )}
  </div>
</section>
