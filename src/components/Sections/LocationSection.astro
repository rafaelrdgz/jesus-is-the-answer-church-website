---
import GoogleMap from "../UI/OpenStreetMap.astro";
import Button from "../UI/Button.astro";
import type { Lang } from "../../i18n/ui";
import { defaultLang } from "../../i18n/ui";
import { useTranslations, useTranslatedPath } from "../../i18n/utils";

export interface Props {
  lang?: Lang;
  variant?: "default" | "im-new";
}

const { lang = defaultLang, variant = "default" } = Astro.props;
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const content = variant === "im-new" ? {
  heading: t('new.locationHeading'),
  subtitle: t('new.locationSubtitle'),
  cardTitle: t('new.addressHeading'),
  address: t('new.churchAddress'),
  directions: [
    { title: t('new.parkingHeading'), text: t('new.parkingText') }
  ],
  showDirections: false,
} : {
  heading: t('contact.locationHeading'),
  subtitle: t('contact.locationSubtitle'),
  cardTitle: t('contact.gettingHere'),
  address: t('footer.fullAddress'),
  directions: [
    { title: t('contact.byCar'), text: t('contact.byCarText') },
    { title: t('contact.publicTransit'), text: t('contact.publicTransitText') },
    { title: t('contact.accessibility'), text: t('contact.accessibilityText') }
  ],
  showDirections: true,
};
---

<section class="py-16 bg-gray-50">
  <div class="container">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{content.heading}</h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        {content.subtitle}
      </p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <div class="bg-gray-200 rounded-lg overflow-hidden h-96">
        <GoogleMap height="100%" className="h-full w-full" markerText={t('footer.churchName')} />
      </div>
      <div>
        <div class="bg-white p-8 rounded-lg shadow-md">
          <h3 class="text-xl font-bold mb-4">{content.cardTitle}</h3>
          <address class="not-italic mb-6 text-gray-700">
            <p class="text-lg">{content.address}</p>
          </address>
          {content.showDirections && (
            <div class="space-y-6">
              {content.directions.map((dir) => (
                <div>
                  <h4 class="font-bold mb-2">{dir.title}</h4>
                  <p class="text-gray-700">{dir.text}</p>
                </div>
              ))}
            </div>
          )}
          {variant === "im-new" && content.directions.map((dir) => (
            <div>
              <h4 class="text-lg font-bold mb-2">{dir.title}</h4>
              <p class="text-gray-700 mb-6">{dir.text}</p>
            </div>
          ))}
          <div class="mt-6">
            <Button href={`https://maps.google.com/?q=${encodeURIComponent(content.address)}`} variant="primary" target="_blank">
              {variant === "im-new" ? t('new.getDirections') : t('contact.getDirections')}
            </Button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
