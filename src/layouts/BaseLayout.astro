---
import "../assets/styles/global.css";
import Seo from "../components/UI/Seo.astro";
import Header from "../components/Global/Header.astro";
import Footer from "../components/Global/Footer.astro";
import type { Lang } from "../i18n/ui";
import { defaultLang } from "../i18n/ui";
import { useTranslations, getAlternateUrl } from "../i18n/utils";

export interface Props {
  title?: string;
  description?: string;
  image?: {
    url: string;
    alt: string;
  };
  type?: "website" | "article";
  canonicalUrl?: string;
  lang?: Lang;
}

const {
  lang = defaultLang,
  title,
  description,
  image = {
    url: "/uploads/church-default.webp",
    alt: "Jesús es la respuesta",
  },
  type = "website",
  canonicalUrl,
} = Astro.props;

const t = useTranslations(lang);

const resolvedTitle = title ?? t('site.title');
const resolvedDescription = description ?? t('site.description');

// Build alternate URLs for hreflang tags
const esUrl = new URL(getAlternateUrl(Astro.url, 'es'), Astro.site);
const enUrl = new URL(getAlternateUrl(Astro.url, 'en'), Astro.site);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <script is:inline>
      // Check for saved language preference and redirect if needed
      (function() {
        const savedLang = localStorage.getItem('preferred-lang');
        const currentPath = window.location.pathname;
        const pathParts = currentPath.split('/').filter(Boolean);
        
        // Get current lang from URL (default is 'es')
        const urlLang = pathParts[0] === 'en' ? 'en' : 'es';
        
        // If there's a saved preference and it differs from current URL, redirect
        if (savedLang && savedLang !== urlLang) {
          // Only redirect if not already in a redirect loop
          if (!sessionStorage.getItem('langRedirectDone')) {
            sessionStorage.setItem('langRedirectDone', 'true');
            // Build new path with saved language
            let newPath = currentPath;
            if (savedLang === 'en') {
              // Add /en/ prefix if going to English
              if (urlLang === 'es') {
                // Remove existing lang prefix and add 'en'
                const restPath = pathParts.slice(1).join('/');
                newPath = '/en/' + (restPath || '');
              }
            } else {
              // Going to Spanish - remove /en/ prefix if present
              if (urlLang === 'en') {
                const restPath = pathParts.slice(1).join('/');
                newPath = '/' + (restPath || '');
              }
            }
            // Preserve query string and hash
            const queryString = window.location.search;
            const hash = window.location.hash;
            window.location.href = newPath + queryString + hash;
          }
        }
        // Clear the redirect flag after page loads
        if (sessionStorage.getItem('langRedirectDone')) {
          sessionStorage.removeItem('langRedirectDone');
        }
      })();
    </script>
    
    <Seo
      title={resolvedTitle}
      description={resolvedDescription}
      image={image}
      type={type}
      canonicalUrl={canonicalUrl}
      lang={lang}
    />
    
    <!-- hreflang alternate links -->
    <link rel="alternate" hreflang="es" href={esUrl.toString()} />
    <link rel="alternate" hreflang="en" href={enUrl.toString()} />
    <link rel="alternate" hreflang="x-default" href={esUrl.toString()} />
    
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body>
    <div class="flex flex-col min-h-screen">
      <Header lang={lang} />
      
      <main class="flex-grow">
        <slot />
      </main>
      
      <Footer lang={lang} />
    </div>

    <script>
      // Save scroll position before page unload (only when it's a language change)
      window.addEventListener('beforeunload', (e) => {
        if (sessionStorage.getItem('isLanguageChange') === 'true') {
          sessionStorage.setItem('scrollPosition', String(window.scrollY));
        }
      });

      // Restore scroll position on page load (only when it was a language change)
      window.addEventListener('load', () => {
        if (sessionStorage.getItem('isLanguageChange') === 'true') {
          const savedPosition = sessionStorage.getItem('scrollPosition');
          if (savedPosition) {
            window.scrollTo(0, parseInt(savedPosition, 10));
          }
          // Clean up flags
          sessionStorage.removeItem('scrollPosition');
          sessionStorage.removeItem('isLanguageChange');
        }
      });
    </script>
  </body>
</html>
