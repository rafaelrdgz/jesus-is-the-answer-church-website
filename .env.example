# Decap CMS OAuth Configuration
# These are the GitHub OAuth App credentials (NOT a personal access token)
# Get them from: https://github.com/settings/developers > OAuth Apps
OAUTH_GITHUB_CLIENT_ID=your_github_oauth_client_id
OAUTH_GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# Site URL - deployment URL (used for Astro site config and Decap CMS OAuth)
SITE_URL=http://localhost:4321
