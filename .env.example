# Decap CMS OAuth Configuration
# Copia este archivo a .env y completa los valores

# OAuth GitHub - Obtén estos de GitHub Developer Settings > OAuth Apps
OAUTH_GITHUB_CLIENT_ID=tu_client_id_aqui
OAUTH_GITHUB_CLIENT_SECRET=tu_client_secret_aqui

# URL del sitio (cambia esto a tu URL de producción)
PUBLIC_SITE_URL=https://tu-sitio.vercel.app
